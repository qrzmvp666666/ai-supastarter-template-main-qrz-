# Database
DATABASE_URL="YOUR_DATABASE_CONNECTION_STRING"
# For local development with Docker Compose:
# DATABASE_URL="postgresql://postgres:postgres@localhost:5432/supastarter"
# ... if you use Supabase
DIRECT_URL=""

# App URLs (used for absolute URLs, sitemaps, auth callbacks, etc.)
NEXT_PUBLIC_MARKETING_URL="http://localhost:3001"
NEXT_PUBLIC_SAAS_URL="http://localhost:3000"

# Docs url
NEXT_PUBLIC_DOCS_URL="http://localhost:3001"

# Authentication
BETTER_AUTH_SECRET="A_RANDOM_SECRET_STRING"
# ... for Github
GITHUB_CLIENT_ID="YOUR_GITHUB_CLIENT_ID"
GITHUB_CLIENT_SECRET="YOUR_GITHUB_CLIENT_SECRET"
# ... for Google
GOOGLE_CLIENT_ID="YOUR_GOOGLE_CLIENT_ID"
GOOGLE_CLIENT_SECRET="YOUR_GOOGLE_CLIENT_SECRET"

# Mails
MAIL_FROM="noreply@example.com"
CONTACT_EMAIL="your-admin@example.com"
# ... with nodemailer
MAIL_HOST=""
MAIL_PORT=""
MAIL_USER=""
MAIL_PASS=""
# ... with Plunk
PLUNK_API_KEY=""
# ... with Resend
RESEND_API_KEY=""
# ... with Postmark
POSTMARK_SERVER_TOKEN=""
# ... with Mailgun
MAILGUN_API_KEY=""
MAILGUN_DOMAIN=""

# Payments
# ... with Lemonsqueezy
LEMONSQUEEZY_API_KEY=""
LEMONSQUEEZY_WEBHOOK_SECRET=""
LEMONSQUEEZY_STORE_ID=""
# ... with Stripe
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
# ... with Creem
CREEM_API_KEY=""
CREEM_WEBHOOK_SECRET=""
# ... with Polar
POLAR_ACCESS_TOKEN=""
POLAR_WEBHOOK_SECRET=""
# ... with DodoPayments
DODO_PAYMENTS_API_KEY=""

# Product price IDs – one per payment method (fallback to generic ID if method-specific not set)
# Credit card
PRICE_ID_PRO_MONTHLY_CARD="price_asdf1234"
PRICE_ID_PRO_YEARLY_CARD="price_asdf1234"
PRICE_ID_LIFETIME_CARD="price_asdf1234"
# WeChat Pay
PRICE_ID_PRO_MONTHLY_WECHAT="price_asdf1234"
PRICE_ID_PRO_YEARLY_WECHAT="price_asdf1234"
PRICE_ID_LIFETIME_WECHAT="price_asdf1234"
# Alipay
PRICE_ID_PRO_MONTHLY_ALIPAY="price_asdf1234"
PRICE_ID_PRO_YEARLY_ALIPAY="price_asdf1234"
PRICE_ID_LIFETIME_ALIPAY="price_asdf1234"

# Product prices and currencies – per payment method
# Amount is a plain integer (e.g. 29 for $29.00, 140 for ¥140). Currency is ISO 4217.
# NEXT_PUBLIC_ prefix is required so these values are available in client components.
# Credit card
NEXT_PUBLIC_PRICE_AMOUNT_PRO_MONTHLY_CARD=29
NEXT_PUBLIC_PRICE_CURRENCY_PRO_MONTHLY_CARD=USD
NEXT_PUBLIC_PRICE_AMOUNT_PRO_YEARLY_CARD=290
NEXT_PUBLIC_PRICE_CURRENCY_PRO_YEARLY_CARD=USD
NEXT_PUBLIC_PRICE_AMOUNT_LIFETIME_CARD=799
NEXT_PUBLIC_PRICE_CURRENCY_LIFETIME_CARD=USD
# WeChat Pay
NEXT_PUBLIC_PRICE_AMOUNT_PRO_MONTHLY_WECHAT=140
NEXT_PUBLIC_PRICE_CURRENCY_PRO_MONTHLY_WECHAT=CNY
NEXT_PUBLIC_PRICE_AMOUNT_PRO_YEARLY_WECHAT=1400
NEXT_PUBLIC_PRICE_CURRENCY_PRO_YEARLY_WECHAT=CNY
NEXT_PUBLIC_PRICE_AMOUNT_LIFETIME_WECHAT=5999
NEXT_PUBLIC_PRICE_CURRENCY_LIFETIME_WECHAT=CNY
# Alipay
NEXT_PUBLIC_PRICE_AMOUNT_PRO_MONTHLY_ALIPAY=140
NEXT_PUBLIC_PRICE_CURRENCY_PRO_MONTHLY_ALIPAY=CNY
NEXT_PUBLIC_PRICE_AMOUNT_PRO_YEARLY_ALIPAY=1400
NEXT_PUBLIC_PRICE_CURRENCY_PRO_YEARLY_ALIPAY=CNY
NEXT_PUBLIC_PRICE_AMOUNT_LIFETIME_ALIPAY=5999
NEXT_PUBLIC_PRICE_CURRENCY_LIFETIME_ALIPAY=CNY

# Analytics
